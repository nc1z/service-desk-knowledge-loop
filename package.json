{
  "name": "service-desk-knowledge-loop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "demo:run": "node scripts/demo-run.mjs",
    "brief:pattern": "node scripts/generate-incident-brief.mjs",
    "cluster:incidents": "node scripts/cluster-incidents.mjs",
    "brief:incident": "node scripts/generate-incident-brief.mjs",
    "build": "tsc --noEmit && vite build",
    "check:vpn-demo": "node scripts/check-vpn-session-demo.mjs --ticket INC-2026-0001 --stage after-mfa",
    "draft:kb": "node scripts/generate-kb-draft.mjs",
    "eval:service-desk-loop": "node scripts/eval-service-desk-loop.mjs",
    "eval:poc": "node scripts/eval-service-desk-loop.mjs",
    "handoff:review": "node scripts/generate-reviewer-handoff.mjs",
    "ingest:tickets": "node scripts/ingest-tickets.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "reset:demo": "node scripts/reset-demo.mjs",
    "test": "node --test",
    "validate:runbooks": "node scripts/validate-runbooks.mjs",
    "verify:acceptance": "node scripts/verify-acceptance.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "eslint": "9.39.4",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2",
    "vite": "7.3.3"
  }
}
