{
  "name": "service-desk-knowledge-loop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "brief:pattern": "node scripts/generate-incident-brief.mjs",
    "cluster:incidents": "node scripts/cluster-incidents.mjs",
    "brief:incident": "node scripts/generate-incident-brief.mjs",
    "build": "tsc --noEmit && vite build",
    "ingest:tickets": "node scripts/ingest-tickets.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node --test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "eslint": "9.39.4",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2",
    "vite": "7.3.3"
  }
}
